<Window x:Class="HDMIViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HDMI Viewer"
        Height="700"
        Width="1100"
        KeyDown="Window_KeyDown">
    <!-- 监听全局键盘事件，按 ESC 退出全屏 -->

    <Grid>
        <Grid.RowDefinitions>
            <!-- 给控制栏和状态栏命名，方便全屏时彻底隐藏它们 -->
            <RowDefinition x:Name="ControlRow" Height="Auto"/>
            <RowDefinition x:Name="StatusRow" Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 参数控制栏 -->
        <StackPanel x:Name="ControlPanel" Orientation="Horizontal" Grid.Row="0" Margin="15,10,15,5" VerticalAlignment="Center">
            <!-- 通道选择 -->
            <TextBlock Text="通道号:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="ChannelComboBox" Width="70" Height="30" VerticalContentAlignment="Center" Margin="0,0,15,0">
                <ComboBoxItem Content="0" IsSelected="True"/>
                <ComboBoxItem Content="1"/>
                <ComboBoxItem Content="2"/>
                <ComboBoxItem Content="3"/>
            </ComboBox>

            <!-- 宽度输入 -->
            <TextBlock Text="宽度(Width):" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="WidthTextBox" Text="1920" Width="60" Height="30" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="0,0,15,0"/>

            <!-- 高度输入 -->
            <TextBlock Text="高度(Height):" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="HeightTextBox" Text="1080" Width="60" Height="30" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="0,0,15,0"/>

            <!-- 编码格式选择 -->
            <TextBlock Text="格式:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="FormatComboBox" Width="90" Height="30" VerticalContentAlignment="Center" Margin="0,0,20,0">
                <ComboBoxItem Content="MJPEG" IsSelected="True"/>
                <ComboBoxItem Content="YUY2"/>
                <ComboBoxItem Content="默认"/>
            </ComboBox>

            <!-- 打开按钮 -->
            <Button x:Name="OpenButton" Content="打开采集卡"
                    Width="110" Height="30" Margin="0,0,10,0"
                    Click="Open_Click"/>

            <!-- 停止按钮 -->
            <Button x:Name="StopButton" Content="停止采集"
                    Width="110" Height="30" Margin="0,0,15,0" IsEnabled="False"
                    Click="Stop_Click"/>

            <!-- 全屏按钮 -->
            <Button x:Name="FullScreenButton" Content="全屏显示"
                    Width="90" Height="30"
                    Click="FullScreen_Click"/>
        </StackPanel>

        <!-- 状态文本 -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="1"
                   Margin="15,0,15,5"
                   Foreground="Gray"
                   Text="未启动"/>

        <!-- 视频显示框（加入 MouseLeftButtonDown 事件支持双击全屏） -->
        <Border Grid.Row="2" Background="Black" Margin="0" 
                MouseLeftButtonDown="VideoBorder_MouseLeftButtonDown">
            <Image x:Name="VideoImage"
                   Stretch="Uniform"/>
        </Border>

    </Grid>
</Window>