<Window x:Class="HDMIViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HDMI Viewer"
        Height="700"
        Width="1100">

    <Grid Margin="20">

        <StackPanel>

            <Button Content="扫描视频设备"
                    Width="150"
                    Height="40"
                    Click="Scan_Click"/>

            <ListBox x:Name="DeviceList"
                     Margin="0,20,0,0"
                     Height="400"/>

        </StackPanel>

    </Grid>
</Window>